# Copy to .env and fill in your values for local testing
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=-100YOUR_CHANNEL_ID
TELEGRAM_OPS_CHAT_ID=-100YOUR_CHANNEL_ID

# Mode: "vehicles", "interns", or "both"
MODE=both

# Vehicle tracker config
MAX_PRICE_LKR=30000000
MAX_PAGES_PER_SITE=10
NEWS_ENABLED=true

# Intern tracker config
INTERN_MAX_PAGES_PER_SITE=5
